{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Python File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            // 自动继承 VS Code 选中的 Conda 解释器路径
            //"python": "${command:python.interpreterPath}"
            "python": "/home/liuli/miniconda3/envs/py37-tf22gpu/bin/python" 
        },

        {
            "name": "Python: Attach to debugpy (远程训练)",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}",
                    "remoteRoot": "${workspaceFolder}"
                }
            ],
            "justMyCode": true,
            "console": "integratedTerminal"
        }


    ]
}